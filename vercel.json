{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "frontend/js/$1" },
    { "src": "/assets/(.*)", "dest": "frontend/assets/$1" },
    { "src": "/ws", "dest": "main.py" },
    { "src": "/(.*)", "dest": "main.py" }
  ]
}
