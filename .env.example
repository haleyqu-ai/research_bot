# Meshy User Interview Bot — Environment Variables

# LLM (Gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud (STT & TTS) — can reuse GEMINI_API_KEY if same project
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key

# Feishu (Lark) integration — for saving transcripts to Wiki
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_WIKI_SPACE_ID=your-feishu-wiki-space-id
FEISHU_WIKI_PARENT_NODE=your-feishu-wiki-parent-node-token
